{
  "name": "openclaw-installer-control",
  "private": true,
  "version": "0.1.1",
  "description": "Local control UI for OpenClaw installer on macOS and Windows.",
  "author": "megabyai",
  "type": "module",
  "main": "app/electron-main.mjs",
  "scripts": {
    "control-app": "node app/server.mjs",
    "desktop": "electron .",
    "dist": "electron-builder --publish never",
    "build:mac": "electron-builder --publish never --mac zip --x64 --arm64 && node scripts/build-mac-dmg.mjs",
    "build:win": "electron-builder --publish never --win nsis portable",
    "generate-icons": "node scripts/generate-icons.mjs"
  },
  "build": {
    "appId": "cc.megabyai.openclaw.control",
    "productName": "OpenClaw Control",
    "directories": {
      "output": "dist"
    },
    "artifactName": "${productName}-${version}-${arch}-${os}.${ext}",
    "files": [
      "app/**/*",
      "build/**/*",
      "install_openclaw.sh",
      "install_openclaw.ps1",
      "channel_setup.sh",
      "channel_setup.ps1",
      "feishu_browser_automation.js",
      "README.md",
      "package.json"
    ],
    "asar": true,
    "afterSign": "scripts/notarize.mjs",
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "app/assets/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "target": [
        "zip"
      ]
    },
    "win": {
      "icon": "app/assets/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.0",
    "electron": "^35.0.1",
    "electron-builder": "^26.0.12",
    "png-to-ico": "^2.1.8"
  }
}
